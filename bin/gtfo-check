#!/bin/bash
REPO_URL="https://github.com/GTFOBins/GTFOBins.github.io"

echo "[*] Comprobando actualizaciones en GTFOBins..."
cd /tmp/gtfobins-test && git fetch > /dev/null 2>&1
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse @{u})

if [ "$LOCAL" != "$REMOTE" ]; then
    echo "[!] Actualización disponible."
    echo "[*] Ejecutando: gtfo-sync"
    /home/dabit/Security/Tools/gtfo-engine/bin/gtfo-sync
else
    echo "[+] Base de datos al día."
fi
